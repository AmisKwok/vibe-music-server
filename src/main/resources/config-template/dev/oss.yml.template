oss:
  # 支持S3协议的厂商 (MINIO, ALIYUN, TENCENT, QINIU)
  provider: MINIO
  endpoint: http://your-oss-endpoint:9000
  accessKey: "your-access-key"
  secretKey: "your-secret-key"
  bucketName: your-bucket-name
  richtextBucketName: static
  domain: http://your-oss-endpoint:9000
  # 命名方式: UUID、ORIGINAL原文件名偏好，冲突会补充时间
  naming: original
  scheme: https